<screen>
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_APP_BG"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- ========================================================= -->
		<!-- TOP STATUS BAR                                            -->
		<!-- ========================================================= -->
		<global_top_status_bar x="0" y="0" bar_title="GL TOWERS" bar_time="13:20" bar_wifi="WiFi" />

		<!-- ========================================================= -->
		<!-- LEFT SETTINGS MENU                                        -->
		<!-- ========================================================= -->
		<lv_obj
			x="8"
			y="42"
			width="128"
			height="235"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<!-- Active menu item: WiFi -->
			<lv_obj
				x="8"
				y="8"
				width="112"
				height="42"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_MUTED_GRAY"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="0"
				style_pad_all="0"
			>
				<lv_label
					x="10"
					y="7"
					width="92"
					text="WiFi"
					long_mode="clip"
					style_text_color="#COLOR_SUCCESS_GREEN"
					style_text_font="font_inter_12"
				/>

				<lv_label
					x="10"
					y="24"
					width="92"
					text="Network"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_9"
				/>
			</lv_obj>

			<!-- Display -->
			<lv_label
				x="18"
				y="66"
				width="92"
				text="Display"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="18"
				y="82"
				width="92"
				text="Brightness"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
			/>

			<lv_obj
				x="12"
				y="104"
				width="104"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<!-- General -->
			<lv_label
				x="18"
				y="118"
				width="92"
				text="General"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="18"
				y="134"
				width="92"
				text="Units and prefs"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
			/>

			<lv_obj
				x="12"
				y="156"
				width="104"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<!-- Maintenance -->
			<lv_label
				x="18"
				y="170"
				width="92"
				text="Maintenance"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="18"
				y="186"
				width="92"
				text="Service reset"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- WIFI NETWORK DETAILS CARD                                 -->
		<!-- ========================================================= -->
		<lv_obj
			x="144"
			y="42"
			width="328"
			height="212"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="14"
				y="12"
				width="180"
				text="WIFI NETWORK"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN_DARK"
				style_text_font="font_inter_15"
			/>

			<!-- Network row -->
			<lv_label
				x="14"
				y="48"
				width="90"
				text="Network"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="172"
				y="48"
				width="140"
				text="GL_Towers_2.4G"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_obj
				x="14"
				y="70"
				width="300"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<!-- IP address row -->
			<lv_label
				x="14"
				y="82"
				width="90"
				text="IP address"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="204"
				y="82"
				width="108"
				text="192.168.1.60"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_obj
				x="14"
				y="138"
				width="300"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<!-- Status row -->
			<lv_label
				x="14"
				y="116"
				width="90"
				text="Status"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="224"
				y="116"
				width="88"
				text="Connected"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_SUCCESS_GREEN"
				style_text_font="font_inter_11"
			/>

			<!-- Change network button -->
			<lv_obj
				x="14"
				y="174"
				width="300"
				height="28"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="1"
				style_border_color="#COLOR_SUCCESS_GREEN"
				style_pad_all="0"
			>
				<lv_label
					x="0"
					y="8"
					width="300"
					text="CHANGE NETWORK"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_SUCCESS_GREEN"
					style_text_font="font_inter_11"
				/>
			</lv_obj>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- BOTTOM NAVIGATION                                         -->
		<!-- ========================================================= -->
		<global_bottom_nav
			x="0"
			y="280"
			nav_home_text_color="#COLOR_DARK_FOREST"
			nav_sensors_text_color="#COLOR_DARK_FOREST"
			nav_irrigation_text_color="#COLOR_DARK_FOREST"
			nav_led_text_color="#COLOR_DARK_FOREST"
			nav_settings_text_color="#COLOR_STATUS_HEALTHY"
		/>
	</view>
</screen>
