			<lv_label
				x="184"
				y="88"
				width="80"
				text="-48 dBm"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_obj
				x="14"
				y="110"
				width="252"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<!-- IP row -->
			<lv_label
				x="14"
				y="124"
				width="90"
				text="IP"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="150"
				y="124"
				width="114"
				text="192.168.1.60"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_obj
				x="14"
				y="146"
				width="252"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<!-- Network row -->
			<lv_label
				x="14"
				y="160"
				width="90"
				text="Network"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="132"
				y="160"
				width="132"
				text="GL_Towers_2.4G"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<!-- Change WiFi button -->
			<lv_obj
				x="14"
				y="202"
				width="252"
				height="34"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_GL_GREEN_DARK"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="0"
				style_pad_all="0"
			>
				<lv_label
					x="0"
					y="10"
					width="252"
					text="CHANGE WIFI"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_WHITE"
					style_text_font="font_inter_12"
				/>
			</lv_obj>
		</lv_obj>
	</view>
</screen>


