			<lv_obj
				x="12"
				y="158"
				width="152"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<!-- Network 3 -->
			<lv_label
				x="18"
				y="176"
				width="136"
				text="Mobile Hotspot"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
