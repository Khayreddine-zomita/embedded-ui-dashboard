<screen>
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_DARK_FOREST"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- ========================================================= -->
		<!-- TOP BAR                                                   -->
		<!-- ========================================================= -->
		<lv_obj
			x="0"
			y="0"
			width="480"
			height="36"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DARK_FOREST"
			style_bg_opa="255"
			style_border_width="0"
			style_radius="0"
			style_pad_all="0"
		>
			<lv_obj
				x="18"
				y="11"
				width="14"
				height="14"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_GL_GREEN"
				style_bg_opa="255"
				style_radius="7"
				style_border_width="0"
			/>

			<lv_label
				x="46"
				y="10"
				width="160"
				text="WIFI SETUP"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN"
				style_text_font="font_inter_14"
			/>

			<lv_label
				x="360"
				y="10"
				width="52"
				text="13:20"
				long_mode="clip"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>

			<lv_label
				x="426"
				y="10"
				width="44"
				text="WiFi"
				long_mode="clip"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- AVAILABLE NETWORKS CARD                                   -->
		<!-- ========================================================= -->
		<lv_obj
			x="8"
			y="42"
			width="176"
			height="250"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="12"
				y="14"
				width="130"
				text="AVAILABLE"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN_DARK"
				style_text_font="font_inter_14"
			/>

			<!-- Connected network -->
			<lv_obj
				x="10"
				y="44"
				width="156"
				height="52"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_MUTED_GRAY"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="0"
				style_pad_all="0"
			>
				<lv_label
					x="10"
					y="8"
					width="136"
					text="GL_Towers_2.4G"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_11"
				/>

				<lv_label
					x="10"
					y="28"
					width="136"
					text="-48 dBm  Connected"
					long_mode="clip"
					style_text_color="#COLOR_SUCCESS_GREEN"
					style_text_font="font_inter_9"
				/>
			</lv_obj>

			<!-- Network 2 -->
			<lv_label
				x="18"
				y="116"
				width="136"
				text="Greenhouse_AP"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="18"
				y="134"
				width="136"
				text="-62 dBm"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
