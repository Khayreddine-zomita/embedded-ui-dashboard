			<lv_label
				x="18"
				y="194"
				width="136"
				text="-71 dBm"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
			/>

			<!-- Scan indicator -->
			<lv_label
				x="12"
				y="224"
				width="152"
				text="3 networks found"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- CONNECTION CARD                                           -->
		<!-- ========================================================= -->
		<lv_obj
			x="192"
			y="42"
			width="280"
			height="250"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="14"
				y="14"
				width="150"
				text="CONNECTION"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN_DARK"
