<screen>
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_DARK_FOREST"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- ========================================================= -->
		<!-- TOP BAR                                                   -->
		<!-- ========================================================= -->
		<lv_obj
			x="0"
			y="0"
			width="480"
			height="36"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DARK_FOREST"
			style_bg_opa="255"
			style_border_width="0"
			style_radius="0"
			style_pad_all="0"
		>
			<lv_obj
				x="18"
				y="11"
				width="14"
				height="14"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_GL_GREEN"
				style_bg_opa="255"
				style_radius="7"
				style_border_width="0"
			/>

			<lv_label
				x="46"
				y="10"
				width="190"
				text="PH CALIBRATION"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN"
				style_text_font="font_inter_14"
			/>

			<lv_label
				x="392"
				y="10"
				width="60"
				text="1 / 3"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- MAIN PH CALIBRATION CARD                                  -->
		<!-- ========================================================= -->
		<lv_obj
			x="8"
			y="42"
			width="464"
			height="202"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="16"
				y="14"
				width="130"
				text="STEP 1"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN_DARK"
				style_text_font="font_inter_14"
			/>

			<lv_label
				x="16"
				y="44"
				width="390"
				text="Place pH probe in 7.0 reference solution."
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_14"
			/>

			<lv_obj
				x="16"
				y="76"
				width="432"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<lv_label
				x="16"
				y="98"
				width="100"
				text="Reading"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				name="ph_cal_reading"
				x="16"
				y="120"
				width="120"
				text="6.98"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_26"
			/>

			<lv_label
				x="138"
				y="137"
				width="40"
				text="pH"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
			/>

			<!-- Stability indicator -->
			<lv_obj
				x="286"
				y="112"
				width="146"
				height="42"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_MUTED_GRAY"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="0"
				style_pad_all="0"
			>
				<lv_obj
					x="12"
					y="17"
					width="8"
					height="8"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_color="#COLOR_ALERT_ORANGE"
					style_bg_opa="255"
					style_radius="4"
					style_border_width="0"
				/>

				<lv_label
					x="28"
					y="9"
					width="100"
					text="Waiting"
					long_mode="clip"
					style_text_color="#COLOR_ALERT_ORANGE"
					style_text_font="font_inter_11"
				/>

				<lv_label
					x="28"
					y="24"
					width="108"
					text="for stability"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_9"
				/>
			</lv_obj>

			<lv_label
				x="16"
				y="176"
				width="330"
				text="Save point only after the reading is stable."
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_10"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- CANCEL BUTTON                                             -->
		<!-- ========================================================= -->
		<lv_obj
			x="8"
			y="254"
			width="226"
			height="48"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="0"
				y="16"
				width="226"
				text="CANCEL"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- SAVE POINT BUTTON                                         -->
		<!-- ========================================================= -->
		<lv_obj
			x="246"
			y="254"
			width="226"
			height="48"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_GL_GREEN_DARK"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="0"
		>
			<lv_label
				x="0"
				y="16"
				width="226"
				text="SAVE POINT"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>
		</lv_obj>
	</view>
</screen>


