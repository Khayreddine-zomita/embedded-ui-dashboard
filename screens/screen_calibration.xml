				x="10"
				y="146"
				width="128"
				height="32"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
