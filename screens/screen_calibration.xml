		</lv_obj>

		<!-- ========================================================= -->
		<!-- pH PROBE CARD                                             -->
		<!-- ========================================================= -->
		<lv_obj
			x="8"
			y="42"
			width="148"
			height="190"
			scrollable="false"
			scrollbar_mode="off"
