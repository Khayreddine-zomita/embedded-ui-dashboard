		<!-- STATUS / NOTE CARD                                        -->
		<!-- ========================================================= -->
		<lv_obj
			x="8"
			y="244"
			width="464"
			height="48"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_MUTED_GRAY"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="0"
