				x="14"
				y="10"
				width="330"
				text="Calibration flows use stable readings"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="14"
				y="26"
				width="330"
				text="before saving sensor offsets."
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_10"
			/>

			<lv_label
				x="374"
				y="17"
				width="76"
				text="READY"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_SUCCESS_GREEN"
				style_text_font="font_inter_11"
			/>
