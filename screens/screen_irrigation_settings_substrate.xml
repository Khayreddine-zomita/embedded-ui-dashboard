<screen name="screen_irrigation_substrate">
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_APP_BG"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<global_top_status_bar x="0" y="0" bar_title="GL TOWERS" bar_time="13:20" bar_wifi="WiFi" />

		<!-- Page title -->
		<lv_label
			name="edit_irrigation_settings_title_label"
			x="16"
			y="52"
			width="340"
			text="Substrate"
			long_mode="clip"
			style_text_color="#COLOR_PRIMARY_GREEN"
			style_text_font="font_inter_14"
		/>

		<!-- Main card -->
		<lv_obj
			name="irrigation_substrate_card"
			x="14"
			y="76"
			width="452"
			height="193"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="18"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_shadow_width="8"
			style_shadow_opa="16"
			style_shadow_color="#COLOR_SHADOW"
			style_shadow_offset_y="3"
		>
			<!-- Soil / Mixed -->
			<lv_button
				name="irrigation_substrate_soil_mixed_btn"
				x="18"
				y="10"
				width="416"
				height="32"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="10"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_image
					name="irrigation_substrate_soil_mixed_icon"
					x="16"
					y="4"
					width="24"
					height="24"
					src="img_irrigation_mixed_soil_substrate_16px"
					scrollable="false"
					scrollbar_mode="off"
				/>

				<lv_label
					name="irrigation_substrate_soil_mixed_name_label"
					x="56"
					y="1"
					width="210"
					text="Soil / Mixed"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>

				<lv_label
					name="irrigation_substrate_soil_mixed_desc_label"
					x="56"
					y="16"
					width="275"
					text="Long dry periods to prevent waterlogging"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_10"
				/>

				<lv_obj
					name="irrigation_substrate_soil_mixed_radio_circle"
					x="376"
					y="5"
					width="20"
					height="20"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_opa="0"
					style_radius="10"
					style_border_width="2"
					style_border_color="#COLOR_DIVIDER"
					style_pad_all="0"
				/>
			</lv_button>

			<!-- Coco Coir -->
			<lv_button
				name="irrigation_substrate_coco_coir_btn"
				x="18"
				y="47"
				width="416"
				height="32"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="10"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_image
					name="irrigation_substrate_coco_coir_icon"
					x="16"
					y="4"
					width="24"
					height="24"
					src="img_irrigation_coco_coir_substrate_16px"
					scrollable="false"
					scrollbar_mode="off"
				/>

				<lv_label
					name="irrigation_substrate_coco_coir_name_label"
					x="56"
					y="1"
					width="210"
					text="Coco Coir"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>

				<lv_label
					name="irrigation_substrate_coco_coir_desc_label"
					x="56"
					y="16"
					width="275"
					text="High retention - longer dry period"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_10"
				/>

				<lv_obj
					name="irrigation_substrate_coco_coir_radio_circle"
					x="376"
					y="5"
					width="20"
					height="20"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_opa="0"
					style_radius="10"
					style_border_width="2"
					style_border_color="#COLOR_DIVIDER"
					style_pad_all="0"
				/>
			</lv_button>

			<!-- Rockwool -->
			<lv_button
				name="irrigation_substrate_rockwool_btn"
				x="18"
				y="84"
				width="416"
				height="32"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="10"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_image
					name="irrigation_substrate_rockwool_icon"
					x="16"
					y="4"
					width="24"
					height="24"
					src="img_irrigation_rockwool_substrate_16px"
					scrollable="false"
					scrollbar_mode="off"
				/>

				<lv_label
					name="irrigation_substrate_rockwool_name_label"
					x="56"
					y="1"
					width="210"
					text="Rockwool"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>

				<lv_label
					name="irrigation_substrate_rockwool_desc_label"
					x="56"
					y="16"
					width="275"
					text="Balanced cycle frequency"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_10"
				/>

				<lv_obj
					name="irrigation_substrate_rockwool_radio_circle"
					x="376"
					y="5"
					width="20"
					height="20"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_opa="0"
					style_radius="10"
					style_border_width="2"
					style_border_color="#COLOR_DIVIDER"
					style_pad_all="0"
				/>
			</lv_button>

			<!-- Clay Pebbles -->
			<lv_button
				name="irrigation_substrate_clay_pebbles_btn"
				x="18"
				y="121"
				width="416"
				height="32"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="10"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_image
					name="irrigation_substrate_clay_pebbles_icon"
					x="16"
					y="4"
					width="24"
					height="24"
					src="img_irrigation_clay_pebbles_substrate_16px"
					scrollable="false"
					scrollbar_mode="off"
				/>

				<lv_label
					name="irrigation_substrate_clay_pebbles_name_label"
					x="56"
					y="1"
					width="210"
					text="Clay Pebbles"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>

				<lv_label
					name="irrigation_substrate_clay_pebbles_desc_label"
					x="56"
					y="16"
					width="275"
					text="Fast drainage - frequent cycles"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_10"
				/>

				<lv_obj
					name="irrigation_substrate_clay_pebbles_radio_circle"
					x="376"
					y="5"
					width="20"
					height="20"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_opa="0"
					style_radius="10"
					style_border_width="2"
					style_border_color="#COLOR_DIVIDER"
					style_pad_all="0"
				/>
			</lv_button>

			<!-- Hydroponic selected -->
			<lv_button
				name="irrigation_substrate_hydroponic_btn"
				x="18"
				y="158"
				width="416"
				height="32"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_LIGHT_GREEN"
				style_bg_opa="90"
				style_radius="10"
				style_border_width="1"
				style_border_color="#COLOR_PRIMARY_GREEN"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_image
					name="irrigation_substrate_hydroponic_icon"
					x="16"
					y="3"
					width="24"
					height="24"
					src="img_irrigation_drop_silhouette_substrate_16px"
					style_image_recolor="#COLOR_STATUS_INFO"
					style_image_recolor_opa="255"
					scrollable="false"
					scrollbar_mode="off"
				/>

				<lv_label
					name="irrigation_substrate_hydroponic_name_label"
					x="56"
					y="1"
					width="210"
					text="Hydroponic"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>

				<lv_label
					name="irrigation_substrate_hydroponic_desc_label"
					x="56"
					y="16"
					width="275"
					text="NFT / DWC - frequent short cycles for roots oxygenation"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_10"
				/>

				<lv_obj
					name="irrigation_substrate_hydroponic_selected_circle"
					x="376"
					y="5"
					width="20"
					height="20"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_color="#COLOR_PRIMARY_GREEN"
					style_bg_opa="255"
					style_radius="10"
					style_border_width="0"
					style_pad_all="0"
				>
					<lv_obj
						name="irrigation_substrate_hydroponic_selected_dot"
						x="7"
						y="7"
						width="6"
						height="6"
						scrollable="false"
						scrollbar_mode="off"
						style_bg_color="#COLOR_WHITE"
						style_bg_opa="255"
						style_radius="3"
						style_border_width="0"
						style_pad_all="0"
					/>
				</lv_obj>
			</lv_button>
		</lv_obj>

		<!-- Bottom actions -->
		<lv_button
			name="irrigation_growth_stage_back_btn"
			x="14"
			y="275"
			width="152"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="irrigation_growth_stage_back_label"
				x="0"
				y="8"
				width="150"
				text="Cancel"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>
		</lv_button>

		<lv_button
			name="irrigation_growth_stage_apply_btn"
			x="180"
			y="275"
			width="286"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_PRIMARY_GREEN"
			style_bg_opa="255"
			style_radius="10"
			style_border_width="0"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="irrigation_growth_stage_apply_label"
				x="40"
				y="8"
				width="200"
				text="Apply Substrate"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>
		</lv_button>
	</view>
</screen>
