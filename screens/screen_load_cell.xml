<screen>
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_DARK_FOREST"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- ========================================================= -->
		<!-- TOP BAR                                                   -->
		<!-- ========================================================= -->
		<lv_obj
			x="0"
			y="0"
			width="480"
			height="36"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DARK_FOREST"
			style_bg_opa="255"
			style_border_width="0"
			style_radius="0"
			style_pad_all="0"
		>
			<lv_obj
				x="18"
				y="11"
				width="14"
				height="14"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_GL_GREEN"
				style_bg_opa="255"
				style_radius="7"
				style_border_width="0"
			/>

			<lv_label
				x="46"
				y="10"
				width="160"
				text="LOAD CELL"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN"
				style_text_font="font_inter_14"
			/>

			<lv_label
				x="360"
				y="10"
				width="52"
				text="13:20"
				long_mode="clip"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>

			<lv_label
				x="426"
				y="10"
				width="44"
				text="WiFi"
				long_mode="clip"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- TANK WEIGHT CARD                                          -->
		<!-- ========================================================= -->
		<lv_obj
			x="8"
			y="42"
			width="228"
			height="250"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="14"
				y="14"
				width="150"
				text="TANK WEIGHT"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN_DARK"
				style_text_font="font_inter_14"
			/>

			<lv_label
				name="load_cell_liters"
				x="14"
				y="58"
				width="120"
				text="6.0 L"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_26"
			/>

			<lv_label
				x="14"
				y="112"
				width="120"
				text="Reservoir level"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>

			<!-- Progress background -->
			<lv_obj
				x="14"
				y="140"
				width="200"
				height="10"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_MUTED_GRAY"
				style_bg_opa="255"
				style_radius="5"
				style_border_width="0"
				style_pad_all="0"
			>
				<!-- Progress fill: 92% -->
				<lv_obj
					x="0"
					y="0"
					width="184"
					height="10"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_color="#COLOR_GL_GREEN"
					style_bg_opa="255"
					style_radius="5"
					style_border_width="0"
					style_pad_all="0"
				/>
			</lv_obj>

			<lv_label
				x="14"
				y="168"
				width="90"
				text="92% full"
				long_mode="clip"
				style_text_color="#COLOR_SUCCESS_GREEN"
				style_text_font="font_inter_12"
			/>

			<lv_label
				x="126"
				y="168"
				width="88"
				text="6.5 L max"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>

			<lv_obj
				x="14"
				y="200"
				width="200"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<lv_label
				x="14"
				y="218"
				width="200"
				text="Load cell reading is stable"
				long_mode="clip"
				style_text_color="#COLOR_SUCCESS_GREEN"
				style_text_font="font_inter_10"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- CALIBRATION CARD                                          -->
		<!-- ========================================================= -->
		<lv_obj
			x="244"
			y="42"
			width="228"
			height="250"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="14"
				y="14"
				width="150"
				text="CALIBRATION"
				long_mode="clip"
				style_text_color="#COLOR_ALERT_ORANGE"
				style_text_font="font_inter_14"
			/>

			<lv_label
				x="14"
				y="52"
				width="190"
				text="Empty tank before tare."
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_14"
			/>

			<lv_label
				x="14"
				y="78"
				width="190"
				text="Use known volume for final calibration."
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_10"
			/>

			<!-- Tare empty button -->
			<lv_obj
				x="14"
				y="116"
				width="200"
				height="38"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="8"
				style_pad_all="0"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
			>
				<lv_label
					x="0"
					y="12"
					width="200"
					text="TARE EMPTY"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>
			</lv_obj>

			<!-- Calibrate 6.5L button -->
			<lv_obj
				x="14"
				y="166"
				width="200"
				height="38"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_GL_GREEN_DARK"
				style_bg_opa="255"
				style_radius="8"
				style_pad_all="0"
				style_border_width="0"
			>
				<lv_label
					x="0"
					y="12"
					width="200"
					text="CAL 6.5 L"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_WHITE"
					style_text_font="font_inter_12"
				/>
			</lv_obj>

			<lv_label
				x="14"
				y="224"
				width="200"
				text="Calibration status: ready"
				long_mode="clip"
				style_text_color="#COLOR_SUCCESS_GREEN"
				style_text_font="font_inter_10"
			/>
		</lv_obj>
	</view>
</screen>


