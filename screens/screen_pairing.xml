<screen>
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_DARK_FOREST"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- ========================================================= -->
		<!-- TOP BAR                                                   -->
		<!-- ========================================================= -->
		<lv_obj
			x="0"
			y="0"
			width="480"
			height="36"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DARK_FOREST"
			style_bg_opa="255"
			style_border_width="0"
			style_radius="0"
			style_pad_all="0"
		>
			<lv_obj
				x="18"
				y="11"
				width="14"
				height="14"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_GL_GREEN"
				style_bg_opa="255"
				style_radius="7"
				style_border_width="0"
			/>

			<lv_label
				x="46"
				y="10"
				width="190"
				text="DEVICE PAIRING"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN"
				style_text_font="font_inter_14"
			/>

			<lv_label
				x="360"
				y="10"
				width="52"
				text="13:20"
				long_mode="clip"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>

			<lv_label
				x="426"
				y="10"
				width="44"
				text="WiFi"
				long_mode="clip"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- QR CARD                                                   -->
		<!-- ========================================================= -->
		<lv_obj
			x="8"
			y="42"
			width="156"
			height="250"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="14"
				y="14"
				width="120"
				text="SCAN CODE"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN_DARK"
				style_text_font="font_inter_14"
			/>

			<!-- QR white container -->
			<lv_obj
				x="18"
				y="48"
				width="120"
				height="120"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_WHITE"
				style_bg_opa="255"
				style_radius="6"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
			>
				<!-- Built-in pairing QR code -->
				<lv_qrcode
					name="pairing_qr"
					x="4"
					y="4"
					size="112"
					data="GLTOWER:PAIR:GL-4821"
					dark_color="#COLOR_TEXT_PRIMARY"
					light_color="#COLOR_WHITE"
					quiet_zone="true"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_color="#COLOR_WHITE"
					style_bg_opa="255"
					style_border_width="0"
					style_radius="0"
					style_pad_all="0"
				/>
			</lv_obj>

			<lv_label
				x="0"
				y="178"
				width="156"
				text="Scan to pair"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="0"
				y="198"
				width="156"
				text="with mobile app"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_10"
			/>

			<lv_obj
				x="28"
				y="224"
				width="100"
				height="12"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_SUCCESS_GREEN"
				style_bg_opa="255"
				style_radius="6"
				style_border_width="0"
				style_pad_all="0"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- PAIRING DETAILS CARD                                      -->
		<!-- ========================================================= -->
		<lv_obj
			x="172"
			y="42"
			width="300"
			height="250"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="14"
				y="14"
				width="150"
				text="PAIRING CODE"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN_DARK"
				style_text_font="font_inter_14"
			/>

			<lv_label
				name="pairing_code"
				x="14"
				y="54"
				width="180"
				text="GL-4821"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_26"
			/>

			<lv_label
				x="14"
				y="102"
				width="250"
				text="Device broadcasts for 5 minutes."
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
			/>

			<lv_obj
				x="14"
				y="132"
				width="272"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<!-- Pairing status -->
			<lv_label
				x="14"
				y="150"
				width="90"
				text="Status"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				name="pairing_status"
				x="188"
				y="150"
				width="98"
				text="Broadcasting"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_SUCCESS_GREEN"
				style_text_font="font_inter_11"
			/>

			<!-- Time remaining -->
			<lv_label
				x="14"
				y="176"
				width="120"
				text="Time remaining"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				name="pairing_timer"
				x="226"
				y="176"
				width="60"
				text="04:59"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<!-- Restart pairing button -->
			<lv_obj
				x="14"
				y="204"
				width="272"
				height="34"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_GL_GREEN_DARK"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="0"
				style_pad_all="0"
			>
				<lv_label
					x="0"
					y="10"
					width="272"
					text="RESTART PAIRING"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_WHITE"
					style_text_font="font_inter_12"
				/>
			</lv_obj>
		</lv_obj>
	</view>
</screen>


