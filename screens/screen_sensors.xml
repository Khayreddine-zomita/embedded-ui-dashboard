<screen name="screen_sensors">
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_WHITE"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- ========================================================= -->
		<!-- TOP STATUS BAR                                            -->
		<!-- ========================================================= -->
		<global_top_status_bar x="0" y="0" bar_title="GL TOWERS" bar_time="13:20" />

		<!-- ========================================================= -->
		<!-- SENSOR CARDS - PROTOTYPE 1 SENSOR SCOPE                   -->
		<!-- pH and EC removed from first prototype                    -->
		<!-- ========================================================= -->

		<sensors_screen_card
			x="8"
			y="40"
			sensor_title="WATER TEMP"
			sensor_value="22.3"
			sensor_unit="°C"
			sensor_unit_x="74"
			sensor_status="Optimal"
			sensor_hint="Target 18 - 23 C"
			sensor_color="#COLOR_STATUS_INFO"
			sensor_status_color="#COLOR_STATUS_HEALTHY"
			sensor_status_bg_color="#COLOR_LIGHT_GREEN"
			trend_values="48 52 50 55 53 58 56 62"
			trend_min="40"
			trend_max="80"
		/>

		<sensors_screen_card
			x="246"
			y="40"
			sensor_title="AIR TEMP"
			sensor_value="23.0"
			sensor_unit="°C"
			sensor_unit_x="74"
			sensor_status="Good"
			sensor_hint="Target 16 - 24 C"
			sensor_color="#COLOR_ALERT_ORANGE"
			sensor_status_color="#COLOR_STATUS_HEALTHY"
			sensor_status_bg_color="#COLOR_LIGHT_GREEN"
			trend_values="50 53 52 56 54 58 57 61"
			trend_min="40"
			trend_max="80"
		/>

		<sensors_screen_card
			x="8"
			y="160"
			sensor_title="HUMIDITY"
			sensor_value="71"
			sensor_unit="%"
			sensor_unit_x="48"
			sensor_status="Good"
			sensor_hint="Target 80 - 99%"
			sensor_color="#COLOR_PURPLE"
			sensor_status_color="#COLOR_STATUS_HEALTHY"
			sensor_status_bg_color="#COLOR_LIGHT_GREEN"
			trend_values="52 55 54 58 57 61 59 64"
			trend_min="40"
			trend_max="80"
		/>

		<sensors_screen_card
			x="246"
			y="160"
			sensor_title="TANK WEIGHT"
			sensor_value="6.0"
			sensor_unit="L"
			sensor_unit_x="58"
			sensor_status="Normal"
			sensor_hint="Estimated volume"
			sensor_color="#COLOR_PRIMARY_GREEN"
			sensor_status_color="#COLOR_STATUS_HEALTHY"
			sensor_status_bg_color="#COLOR_LIGHT_GREEN"
			trend_values="72 70 68 66 65 63 61 60"
			trend_min="40"
			trend_max="80"
		/>

		<!-- ========================================================= -->
		<!-- BOTTOM NAVIGATION                                         -->
		<!-- ========================================================= -->
		<global_bottom_nav
			x="0"
			y="280"
			nav_home_text_color="#COLOR_WHITE"
			nav_sensors_text_color="#COLOR_WHITE"
			nav_irrigation_text_color="#COLOR_WHITE"
			nav_led_text_color="#COLOR_WHITE"
			nav_settings_text_color="#COLOR_WHITE"
			nav_home_bg_color="#COLOR_DARK_FOREST"
			nav_sensors_bg_color="#COLOR_PRIMARY_GREEN"
			nav_irrigation_bg_color="#COLOR_DARK_FOREST"
			nav_led_bg_color="#COLOR_DARK_FOREST"
			nav_settings_bg_color="#COLOR_DARK_FOREST"
			nav_home_bg_opa="0"
			nav_sensors_bg_opa="255"
			nav_irrigation_bg_opa="0"
			nav_led_bg_opa="0"
			nav_settings_bg_opa="0"
		/>
	</view>
</screen>
