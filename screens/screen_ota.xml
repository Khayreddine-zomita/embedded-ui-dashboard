<screen>
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_DARK_FOREST"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- ========================================================= -->
		<!-- TOP BAR                                                   -->
		<!-- ========================================================= -->
		<lv_obj
			x="0"
			y="0"
			width="480"
			height="36"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DARK_FOREST"
			style_bg_opa="255"
			style_border_width="0"
			style_radius="0"
			style_pad_all="0"
		>
			<lv_obj
				x="18"
				y="11"
				width="14"
				height="14"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_GL_GREEN"
				style_bg_opa="255"
				style_radius="7"
				style_border_width="0"
			/>

			<lv_label
				x="46"
				y="10"
				width="160"
				text="OTA UPDATE"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN"
				style_text_font="font_inter_14"
			/>

			<lv_label
				x="360"
				y="10"
				width="52"
				text="13:20"
				long_mode="clip"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>

			<lv_label
				x="426"
				y="10"
				width="44"
				text="WiFi"
				long_mode="clip"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- FIRMWARE CARD                                             -->
		<!-- ========================================================= -->
		<lv_obj
			x="8"
			y="42"
			width="156"
			height="250"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="12"
				y="14"
				width="120"
				text="FIRMWARE"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN_DARK"
				style_text_font="font_inter_14"
			/>

			<lv_label
				x="12"
				y="54"
				width="100"
				text="Current"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_10"
			/>

			<lv_label
				name="firmware_version"
				x="12"
				y="76"
				width="100"
				text="0.1.0"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_26"
			/>

			<lv_obj
				x="12"
				y="124"
				width="132"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<lv_label
				x="12"
				y="142"
				width="120"
				text="Channel"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_10"
			/>

			<lv_label
				x="12"
				y="160"
				width="120"
				text="production"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_11"
			/>

			<lv_label
				x="12"
				y="194"
				width="120"
				text="WiFi"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_10"
			/>

			<lv_label
				x="12"
				y="212"
				width="120"
				text="Connected"
				long_mode="clip"
				style_text_color="#COLOR_SUCCESS_GREEN"
				style_text_font="font_inter_11"
			/>
		</lv_obj>

		<!-- ========================================================= -->
		<!-- UPDATE STATUS CARD                                        -->
		<!-- ========================================================= -->
		<lv_obj
			x="172"
			y="42"
			width="300"
			height="250"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
		>
			<lv_label
				x="14"
				y="14"
				width="160"
				text="UPDATE STATUS"
				long_mode="clip"
				style_text_color="#COLOR_GL_GREEN_DARK"
				style_text_font="font_inter_14"
			/>

			<lv_label
				name="ota_status_title"
				x="14"
				y="54"
				width="200"
				text="Ready to check"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_15"
			/>

			<lv_label
				x="14"
				y="88"
				width="240"
				text="No update in progress"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>

			<!-- Built-in OTA progress bar -->
			<lv_bar
				name="ota_progress_bar"
				x="14"
				y="124"
				width="272"
				height="10"
				min_value="0"
				max_value="100"
				value="0"
				mode="normal"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_MUTED_GRAY"
				style_bg_opa="255"
				style_radius="5"
				style_border_width="0"
				style_pad_all="0"
				style_bg_color-indicator="#COLOR_GL_GREEN"
				style_bg_opa-indicator="255"
				style_radius-indicator="5"
			/>

			<lv_label
				name="ota_progress_label"
				x="14"
				y="150"
				width="80"
				text="0%"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				x="184"
				y="150"
				width="100"
				text="Idle"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
			/>

			<lv_obj
				x="14"
				y="180"
				width="272"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
			/>

			<!-- Start OTA button -->
			<lv_obj
				x="14"
				y="202"
				width="272"
				height="34"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_GL_GREEN_DARK"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="0"
				style_pad_all="0"
			>
				<lv_label
					x="0"
					y="10"
					width="272"
					text="START OTA"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_WHITE"
					style_text_font="font_inter_12"
				/>
			</lv_obj>
		</lv_obj>
	</view>
</screen>


