<screen name="screen_led_settings">
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_APP_BG"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<global_top_status_bar x="0" y="0" bar_title="GL TOWERS" bar_time="13:20" bar_wifi="WiFi" />

		<!-- Left side: presets -->
		<lv_obj
			name="led_settings_preset_card"
			x="14"
			y="48"
			width="126"
			height="210"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="18"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_shadow_width="8"
			style_shadow_opa="16"
			style_shadow_color="#COLOR_SHADOW"
			style_shadow_offset_y="3"
		>
			<lv_label
				name="led_settings_preset_title_label"
				x="16"
				y="10"
				width="90"
				text="PRESET"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
				style_text_letter_space="1"
			/>

			<lv_button
				name="led_settings_seedling_preset_btn"
				x="14"
				y="36"
				width="98"
				height="28"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="8"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_label
					name="led_settings_seedling_preset_label"
					x="0"
					y="6"
					width="98"
					text="Seedling"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_11"
				/>
			</lv_button>

			<lv_button
				name="led_settings_standard_preset_btn"
				x="14"
				y="70"
				width="98"
				height="28"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_WARNING_BG"
				style_bg_opa="160"
				style_radius="10"
				style_border_width="1"
				style_border_color="#COLOR_STATUS_WARNING"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_label
					name="led_settings_standard_preset_label"
					x="0"
					y="6"
					width="98"
					text="Standard"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_STATUS_WARNING"
					style_text_font="font_inter_11"
				/>
			</lv_button>

			<lv_button
				name="led_settings_bloom_preset_btn"
				x="14"
				y="104"
				width="98"
				height="28"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="10"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_label
					name="led_settings_bloom_preset_label"
					x="0"
					y="6"
					width="98"
					text="Bloom"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_11"
				/>
			</lv_button>

			<lv_button
				name="led_settings_custom_preset_btn"
				x="14"
				y="138"
				width="98"
				height="28"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="10"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_label
					name="led_settings_custom_preset_label"
					x="0"
					y="6"
					width="98"
					text="Custom"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_11"
				/>
			</lv_button>

			<lv_button
				name="led_settings_off_preset_btn"
				x="14"
				y="172"
				width="98"
				height="28"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="10"
				style_border_width="1"
				style_border_color="#COLOR_DIVIDER"
				style_pad_all="0"
				style_shadow_width="0"
			>
				<lv_label
					name="led_settings_off_preset_label"
					x="0"
					y="5"
					width="98"
					text="Off"
					long_mode="clip"
					style_text_align="center"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_11"
				/>
			</lv_button>
		</lv_obj>

		<!-- Right side: schedule -->
		<lv_obj
			name="led_settings_schedule_card"
			x="152"
			y="48"
			width="314"
			height="106"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="18"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_shadow_width="8"
			style_shadow_opa="16"
			style_shadow_color="#COLOR_SHADOW"
			style_shadow_offset_y="3"
		>
			<lv_label
				name="led_settings_schedule_title_label"
				x="18"
				y="14"
				width="140"
				text="SCHEDULE"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
				style_text_letter_space="1"
			/>

			<lv_label
				name="led_settings_lights_on_label"
				x="18"
				y="40"
				width="110"
				text="Lights ON"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="led_settings_lights_on_value_label"
				x="198"
				y="38"
				width="62"
				text="06:00"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_PRIMARY_GREEN"
				style_text_font="font_inter_15"
			/>

			<lv_button
				name="led_settings_lights_on_time_btn"
				x="268"
				y="30"
				width="34"
				height="34"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_opa="0"
				style_border_width="0"
				style_shadow_width="0"
				style_pad_all="0"
			>
				<lv_image
					name="led_settings_lights_on_clock_icon"
					x="9"
					y="9"
					width="16"
					height="16"
					src="img_irrigation_clock_16px"
					scrollable="false"
					scrollbar_mode="off"
					style_image_recolor="#COLOR_TEXT_PRIMARY"
					style_image_recolor_opa="255"
				/>
			</lv_button>

			<lv_obj
				name="led_settings_schedule_divider"
				x="18"
				y="64"
				width="278"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<lv_label
				name="led_settings_lights_off_label"
				x="18"
				y="76"
				width="110"
				text="Lights OFF"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="led_settings_lights_off_value_label"
				x="198"
				y="74"
				width="62"
				text="22:00"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_PRIMARY_GREEN"
				style_text_font="font_inter_15"
			/>

			<lv_button
				name="led_settings_lights_off_time_btn"
				x="268"
				y="67"
				width="34"
				height="34"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_opa="0"
				style_border_width="0"
				style_shadow_width="0"
				style_pad_all="0"
			>
				<lv_image
					name="led_settings_lights_off_clock_icon"
					x="9"
					y="9"
					width="16"
					height="16"
					src="img_irrigation_clock_16px"
					scrollable="false"
					scrollbar_mode="off"
					style_image_recolor="#COLOR_TEXT_PRIMARY"
					style_image_recolor_opa="255"
				/>
			</lv_button>
		</lv_obj>

		<!-- Right side: intensity -->
		<lv_obj
			name="led_settings_intensity_card"
			x="152"
			y="164"
			width="314"
			height="94"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="18"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_shadow_width="8"
			style_shadow_opa="16"
			style_shadow_color="#COLOR_SHADOW"
			style_shadow_offset_y="3"
		>
			<lv_label
				name="led_settings_intensity_title_label"
				x="18"
				y="14"
				width="140"
				text="INTENSITY"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_12"
				style_text_letter_space="1"
			/>

			<lv_label
				name="led_settings_brightness_label"
				x="18"
				y="44"
				width="100"
				text="Brightness"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="led_settings_brightness_value_label"
				x="214"
				y="20"
				width="80"
				text="80%"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_PRIMARY_GREEN"
				style_text_font="font_inter_26"
			/>

			<!-- Static slider track -->
			<lv_obj
				name="led_settings_intensity_track_bg"
				x="18"
				y="72"
				width="278"
				height="4"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_radius="2"
				style_border_width="0"
				style_pad_all="0"
			/>

			<lv_obj
				name="led_settings_intensity_track_fill"
				x="18"
				y="72"
				width="222"
				height="4"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_PRIMARY_GREEN"
				style_bg_opa="255"
				style_radius="2"
				style_border_width="0"
				style_pad_all="0"
			/>

			<lv_button
				name="led_settings_intensity_knob_btn"
				x="228"
				y="62"
				width="20"
				height="20"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_CARD_BG"
				style_bg_opa="255"
				style_radius="10"
				style_border_width="3"
				style_border_color="#COLOR_PRIMARY_GREEN"
				style_pad_all="0"
				style_shadow_width="0"
			/>
		</lv_obj>

		<!-- Bottom actions -->
		<lv_button
			name="irrigation_growth_stage_back_btn"
			x="14"
			y="275"
			width="152"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="irrigation_growth_stage_back_label"
				x="0"
				y="8"
				width="150"
				text="Cancel"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>
		</lv_button>

		<lv_button
			name="irrigation_growth_stage_apply_btn"
			x="180"
			y="275"
			width="286"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_PRIMARY_GREEN"
			style_bg_opa="255"
			style_radius="10"
			style_border_width="0"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="irrigation_growth_stage_apply_label"
				x="40"
				y="8"
				width="200"
				text="Apply LED"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>
		</lv_button>
	</view>
</screen>
