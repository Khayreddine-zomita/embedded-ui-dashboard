<screen name="screen_edit_irrigation_settings">
	<view
		width="480"
		height="320"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_APP_BG"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<global_top_status_bar x="0" y="0" bar_title="GL TOWERS" bar_time="13:20" bar_wifi="WiFi" />

		<!-- Page title -->
		<lv_label
			name="edit_irrigation_settings_title_label"
			x="16"
			y="52"
			width="340"
			text="EDIT IRRIGATION SETTINGS"
			long_mode="clip"
			style_text_color="#COLOR_BLUE"
			style_text_font="font_inter_14"
		/>

		<!-- Settings card -->
		<lv_obj
			name="edit_irrigation_settings_card"
			x="14"
			y="76"
			width="452"
			height="174"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="18"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_shadow_width="8"
			style_shadow_opa="16"
			style_shadow_color="#COLOR_SHADOW"
			style_shadow_offset_y="3"
		>
			<!-- Growth Stage row -->
			<lv_obj
				name="edit_irrigation_growth_stage_row"
				x="0"
				y="0"
				width="452"
				height="43"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_opa="0"
				style_border_width="0"
				style_radius="0"
				style_pad_all="0"
			>
				<lv_label
					name="edit_irrigation_growth_stage_title_label"
					x="16"
					y="12"
					width="150"
					text="Growth Stage"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>

				<lv_label
					name="edit_irrigation_growth_stage_value_label"
					x="220"
					y="12"
					width="160"
					text="Germination"
					long_mode="clip"
					style_text_align="right"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_12"
				/>

				<lv_image
					name="irrigation_germination_icon"
					x="290"
					y="12"
					width="18"
					height="18"
					src="img_irrigation_growth_stage_germination_color_16px"
					scrollable="false"
					scrollbar_mode="off"
				/>

				<lv_button
					name="edit_irrigation_growth_stage_icon_btn"
					x="410"
					y="2"
					width="38"
					height="38"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_opa="0"
					style_border_width="0"
					style_shadow_width="0"
					style_pad_all="0"
				>
					<lv_image
						name="edit_irrigation_growth_stage_chevron_icon"
						x="7"
						y="7"
						width="24"
						height="24"
						scrollable="false"
						scrollbar_mode="off"
						src="img_simple_chevron_icon_1"
						style_image_recolor="#COLOR_TEXT_SECONDARY"
						style_image_recolor_opa="255"
					/>
				</lv_button>
			</lv_obj>

			<lv_obj
				name="edit_irrigation_settings_divider_1"
				x="16"
				y="43"
				width="420"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Substrate row -->
			<lv_obj
				name="edit_irrigation_substrate_row"
				x="0"
				y="44"
				width="452"
				height="43"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_opa="0"
				style_border_width="0"
				style_radius="0"
				style_pad_all="0"
			>
				<lv_label
					name="edit_irrigation_substrate_title_label"
					x="16"
					y="12"
					width="150"
					text="Substrate"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>

				<lv_label
					name="edit_irrigation_substrate_value_label"
					x="220"
					y="12"
					width="160"
					text="Hydroponic"
					long_mode="clip"
					style_text_align="right"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_12"
				/>

				<lv_image
					name="irrigation_overview_title_drop"
					x="285"
					y="8"
					width="26"
					height="26"
					src="img_irrigation_drop_silhouette_16px"
					scrollable="false"
					scrollbar_mode="off"
					style_image_recolor="#COLOR_STATUS_INFO"
					style_image_recolor_opa="255"
				/>

				<lv_button
					name="edit_irrigation_substrate_icon_btn"
					x="410"
					y="2"
					width="38"
					height="38"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_opa="0"
					style_border_width="0"
					style_shadow_width="0"
					style_pad_all="0"
				>
					<lv_image
						name="edit_irrigation_substrate_chevron_icon"
						x="7"
						y="7"
						width="24"
						height="24"
						scrollable="false"
						scrollbar_mode="off"
						src="img_simple_chevron_icon_1"
						style_image_recolor="#COLOR_TEXT_SECONDARY"
						style_image_recolor_opa="255"
					/>
				</lv_button>
			</lv_obj>

			<lv_obj
				name="edit_irrigation_settings_divider_2"
				x="16"
				y="87"
				width="420"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Pump Cycle row -->
			<lv_obj
				name="edit_irrigation_pump_cycle_row"
				x="0"
				y="88"
				width="452"
				height="43"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_opa="0"
				style_border_width="0"
				style_radius="0"
				style_pad_all="0"
			>
				<lv_label
					name="edit_irrigation_pump_cycle_title_label"
					x="16"
					y="12"
					width="150"
					text="Pump Cycle"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>

				<lv_label
					name="edit_irrigation_pump_cycle_value_label"
					x="220"
					y="12"
					width="160"
					text="1 min / 90 min"
					long_mode="clip"
					style_text_align="right"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_12"
				/>

				<lv_button
					name="edit_irrigation_pump_cycle_icon_btn"
					x="410"
					y="2"
					width="38"
					height="38"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_opa="0"
					style_border_width="0"
					style_shadow_width="0"
					style_pad_all="0"
				>
					<lv_image
						name="edit_irrigation_pump_cycle_chevron_icon"
						x="7"
						y="7"
						width="24"
						height="24"
						scrollable="false"
						scrollbar_mode="off"
						src="img_simple_chevron_icon_1"
						style_image_recolor="#COLOR_TEXT_SECONDARY"
						style_image_recolor_opa="255"
					/>
				</lv_button>
			</lv_obj>

			<lv_obj
				name="edit_irrigation_settings_divider_3"
				x="16"
				y="131"
				width="420"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Irrigation Window row -->
			<lv_obj
				name="edit_irrigation_window_row"
				x="0"
				y="132"
				width="452"
				height="42"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_opa="0"
				style_border_width="0"
				style_radius="0"
				style_pad_all="0"
			>
				<lv_label
					name="edit_irrigation_window_title_label"
					x="16"
					y="12"
					width="160"
					text="Irrigation Window"
					long_mode="clip"
					style_text_color="#COLOR_TEXT_PRIMARY"
					style_text_font="font_inter_12"
				/>

				<lv_label
					name="edit_irrigation_window_value_label"
					x="220"
					y="12"
					width="160"
					text="06:00-22:00"
					long_mode="clip"
					style_text_align="right"
					style_text_color="#COLOR_TEXT_SECONDARY"
					style_text_font="font_inter_12"
				/>

				<lv_button
					name="edit_irrigation_window_icon_btn"
					x="410"
					y="1"
					width="38"
					height="38"
					scrollable="false"
					scrollbar_mode="off"
					style_bg_opa="0"
					style_border_width="0"
					style_shadow_width="0"
					style_pad_all="0"
				>
					<lv_image
						name="edit_irrigation_window_chevron_icon"
						x="7"
						y="7"
						width="24"
						height="24"
						scrollable="false"
						scrollbar_mode="off"
						src="img_simple_chevron_icon_1"
						style_image_recolor="#COLOR_TEXT_SECONDARY"
						style_image_recolor_opa="255"
					/>
				</lv_button>
			</lv_obj>
		</lv_obj>

		<!-- Bottom actions -->
		<lv_button
			name="edit_irrigation_back_btn"
			x="14"
			y="264"
			width="152"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="10"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="edit_irrigation_back_label"
				x="0"
				y="8"
				width="150"
				text="Back"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>
		</lv_button>

		<lv_button
			name="edit_irrigation_save_btn"
			x="180"
			y="264"
			width="286"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_STATUS_HEALTHY"
			style_bg_opa="255"
			style_radius="10"
			style_border_width="0"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="edit_irrigation_save_label"
				x="40"
				y="8"
				width="200"
				text="Save Irrigation"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_12"
			/>
		</lv_button>
	</view>
</screen>
