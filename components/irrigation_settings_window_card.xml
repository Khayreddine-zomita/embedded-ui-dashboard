<component>
	<api>
		<prop name="start_time_text" type="string" />
		<prop name="end_time_text" type="string" />
	</api>

	<view
		width="452"
		height="115"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_CARD_BG"
		style_bg_opa="255"
		style_radius="18"
		style_pad_all="0"
		style_border_width="2"
		style_border_color="#COLOR_DIVIDER"
		style_shadow_width="8"
		style_shadow_opa="16"
		style_shadow_color="#COLOR_SHADOW"
		style_shadow_offset_y="3"
	>
		<lv_label
			name="irrigation_settings_window_title_label"
			x="20"
			y="10"
			width="220"
			text="IRRIGATION WINDOW"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_SECONDARY"
			style_text_font="font_inter_10"
			style_text_letter_space="1"
		/>

		<lv_label
			name="irrigation_settings_window_start_title_label"
			x="20"
			y="40"
			width="150"
			text="Start time"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_14"
		/>

		<lv_label
			name="irrigation_settings_window_start_value_label"
			x="300"
			y="40"
			width="80"
			text="$start_time_text"
			long_mode="clip"
			style_text_align="right"
			style_text_color="#COLOR_PRIMARY_GREEN"
			style_text_font="font_inter_15"
		/>

		<lv_button
			name="irrigation_settings_window_start_time_btn"
			x="396"
			y="32"
			width="36"
			height="36"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_opa="0"
			style_border_width="0"
			style_shadow_width="0"
			style_pad_all="0"
		>
			<lv_image
				name="irrigation_settings_window_start_clock_icon"
				x="10"
				y="10"
				width="16"
				height="16"
				src="img_irrigation_clock_16px"
				scrollable="false"
				scrollbar_mode="off"
				style_image_recolor="#COLOR_TEXT_PRIMARY"
				style_image_recolor_opa="255"
			/>
		</lv_button>

		<lv_obj
			name="irrigation_settings_window_divider"
			x="20"
			y="66"
			width="412"
			height="1"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DIVIDER"
			style_bg_opa="255"
			style_border_width="0"
			style_pad_all="0"
		/>

		<lv_label
			name="irrigation_settings_window_end_title_label"
			x="20"
			y="80"
			width="150"
			text="End time"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_14"
		/>

		<lv_label
			name="irrigation_settings_window_end_value_label"
			x="300"
			y="80"
			width="80"
			text="$end_time_text"
			long_mode="clip"
			style_text_align="right"
			style_text_color="#COLOR_PRIMARY_GREEN"
			style_text_font="font_inter_15"
		/>

		<lv_button
			name="irrigation_settings_window_end_time_btn"
			x="396"
			y="72"
			width="36"
			height="36"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_opa="0"
			style_border_width="0"
			style_shadow_width="0"
			style_pad_all="0"
		>
			<lv_image
				name="irrigation_settings_window_end_clock_icon"
				x="10"
				y="10"
				width="16"
				height="16"
				src="img_irrigation_clock_16px"
				scrollable="false"
				scrollbar_mode="off"
				style_image_recolor="#COLOR_TEXT_PRIMARY"
				style_image_recolor_opa="255"
			/>
		</lv_button>
	</view>
</component>
