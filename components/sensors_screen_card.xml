<component>
	<api>
		<prop name="sensor_title" type="string" />
		<prop name="sensor_value" type="string" />
		<prop name="sensor_unit" type="string" />
		<prop name="sensor_unit_x" type="int" />
		<prop name="sensor_status" type="string" />
		<prop name="sensor_hint" type="string" />
		<prop name="sensor_color" type="color" />
		<prop name="trend_values" type="string" />
		<prop name="trend_min" type="int" />
		<prop name="trend_max" type="int" />
	</api>

	<view
		width="150"
		height="104"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_CARD_BG"
		style_bg_opa="255"
		style_radius="16"
		style_pad_all="0"
		style_border_width="0"
		style_shadow_width="10"
		style_shadow_opa="22"
		style_shadow_color="#COLOR_SHADOW"
		style_shadow_offset_y="4"
	>
		<lv_label
			name="sensor_card_title"
			x="10"
			y="8"
			width="110"
			text="$sensor_title"
			long_mode="clip"
			style_text_color="$sensor_color"
			style_text_font="font_inter_12"
		/>

		<lv_label
			name="sensor_card_value"
			x="10"
			y="25"
			width="78"
			text="$sensor_value"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_26"
		/>

		<lv_label
			name="sensor_card_unit"
			x="$sensor_unit_x"
			y="41"
			width="34"
			text="$sensor_unit"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_9"
		/>

		<lv_label
			name="sensor_card_status"
			x="94"
			y="42"
			width="46"
			text="$sensor_status"
			long_mode="clip"
			style_text_align="right"
			style_text_color="#COLOR_STATUS_HEALTHY"
			style_text_font="font_inter_10"
		/>

		<mini_trend_chart x="19" y="60" trend_min="$trend_min" trend_max="$trend_max" trend_color="$sensor_color" />

		<lv_label
			name="sensor_card_hint"
			x="35"
			y="90"
			width="130"
			text="$sensor_hint"
			long_mode="clip"
			style_text_color="#COLOR_DARK_FOREST"
			style_text_font="font_inter_10"
		/>
	</view>
</component>


