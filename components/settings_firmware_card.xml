<component>
	<api>
		<prop name="current_version" type="string" />
		<prop name="latest_version" type="string" />
		<prop name="update_status" type="string" />
		<prop name="last_checked" type="string" />
	</api>

	<view
		width="452"
		height="217"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_opa="0"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<lv_label
			name="settings_firmware_title_label"
			x="2"
			y="0"
			width="260"
			text="FIRMWARE"
			long_mode="clip"
			style_text_color="#COLOR_PRIMARY_GREEN"
			style_text_font="font_inter_14"
			style_text_letter_space="1"
		/>

		<lv_label
			name="settings_firmware_subtitle_label"
			x="250"
			y="2"
			width="198"
			text="OTA update"
			long_mode="clip"
			style_text_align="right"
			style_text_color="#COLOR_TEXT_SECONDARY"
			style_text_font="font_inter_11"
		/>

		<lv_obj
			name="settings_firmware_info_card"
			x="0"
			y="35"
			width="452"
			height="146"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_CARD_BG"
			style_bg_opa="255"
			style_radius="18"
			style_pad_all="0"
			style_border_width="1"
			style_border_color="#COLOR_DIVIDER"
			style_shadow_width="8"
			style_shadow_opa="16"
			style_shadow_color="#COLOR_SHADOW"
			style_shadow_offset_y="3"
		>
			<!-- Current version -->
			<lv_label
				name="settings_firmware_current_title_label"
				x="18"
				y="12"
				width="170"
				text="Current version"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="settings_firmware_current_value_label"
				x="260"
				y="12"
				width="150"
				text="$current_version"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>

			<lv_obj
				name="settings_firmware_divider_1"
				x="18"
				y="36"
				width="416"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Latest version -->
			<lv_label
				name="settings_firmware_latest_title_label"
				x="18"
				y="48"
				width="170"
				text="Latest version"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="settings_firmware_latest_value_label"
				x="260"
				y="48"
				width="150"
				text="$latest_version"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>

			<lv_obj
				name="settings_firmware_divider_2"
				x="18"
				y="72"
				width="416"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Update status -->
			<lv_label
				name="settings_firmware_status_title_label"
				x="18"
				y="84"
				width="170"
				text="Update status"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="settings_firmware_status_value_label"
				x="230"
				y="84"
				width="180"
				text="$update_status"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_PRIMARY_GREEN"
				style_text_font="font_inter_11"
			/>

			<lv_obj
				name="settings_firmware_divider_3"
				x="18"
				y="108"
				width="416"
				height="1"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_DIVIDER"
				style_bg_opa="255"
				style_border_width="0"
				style_pad_all="0"
			/>

			<!-- Last checked -->
			<lv_label
				name="settings_firmware_checked_title_label"
				x="18"
				y="120"
				width="170"
				text="Last checked"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_12"
			/>

			<lv_label
				name="settings_firmware_checked_value_label"
				x="230"
				y="120"
				width="180"
				text="$last_checked"
				long_mode="clip"
				style_text_align="right"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_11"
			/>
		</lv_obj>
	</view>
</component>
