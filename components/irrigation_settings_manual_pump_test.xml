<component>
	<api>
		<prop name="title_text" type="string" />
		<prop name="description_text" type="string" />
		<prop name="button_text" type="string" />
	</api>

	<view
		width="452"
		height="50"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_CARD_BG"
		style_bg_opa="255"
		style_radius="12"
		style_pad_all="0"
		style_border_width="1"
		style_border_color="#COLOR_DIVIDER"
		style_shadow_width="8"
		style_shadow_opa="16"
		style_shadow_color="#COLOR_SHADOW"
		style_shadow_offset_y="3"
	>
		<lv_label
			name="irrigation_settings_manual_pump_test_title_label"
			x="20"
			y="8"
			width="180"
			text="$title_text"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_14"
		/>

		<lv_label
			name="irrigation_settings_manual_pump_test_desc_label"
			x="20"
			y="28"
			width="260"
			text="$description_text"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_SECONDARY"
			style_text_font="font_inter_10"
		/>

		<lv_button
			name="irrigation_settings_manual_pump_test_btn"
			x="350"
			y="11"
			width="82"
			height="28"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_WATER_TEMP_BG"
			style_bg_opa="120"
			style_radius="10"
			style_border_width="0"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="irrigation_settings_manual_pump_test_btn_label"
				x="0"
				y="6"
				width="82"
				text="$button_text"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_STATUS_INFO"
				style_text_font="font_inter_12"
			/>
		</lv_button>
	</view>
</component>
