		height="106"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_CARD_BG"
		style_bg_opa="255"
		style_radius="18"
		style_pad_all="0"
		style_border_width="2"
		style_border_color="#COLOR_DIVIDER"
