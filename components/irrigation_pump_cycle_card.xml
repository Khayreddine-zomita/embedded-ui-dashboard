		<lv_label
			name="pump_off_value_label"
			x="136"
			y="79"
			width="50"
			text="$pump_off_value"
			long_mode="clip"
			style_text_align="center"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_12"
		/>

		<lv_button
			name="pump_off_plus_btn"
			x="188"
			y="72"
			width="28"
			height="28"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_PRIMARY_GREEN"
			style_bg_opa="255"
			style_radius="14"
			style_border_width="0"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="pump_off_plus_label"
				x="0"
				y="5"
				width="28"
				text="+"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_WHITE"
				style_text_font="font_inter_15"
			/>
		</lv_button>

		<lv_obj
			name="pump_cycle_divider_2"
			x="12"
			y="106"
			width="204"
			height="1"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DIVIDER"
			style_bg_opa="255"
			style_border_width="0"
			style_pad_all="0"
		/>

		<!-- Schedule footer -->
		<lv_label
			name="pump_cycle_schedule_label"
			x="12"
			y="116"
			width="90"
			text="$schedule_label"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_MUTED"
			style_text_font="font_inter_10"
		/>

		<lv_label
			name="pump_cycle_schedule_time_label"
			x="104"
			y="116"
			width="112"
			text="$schedule_time"
			long_mode="clip"
			style_text_align="right"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_10"
		/>
	</view>
</component>


