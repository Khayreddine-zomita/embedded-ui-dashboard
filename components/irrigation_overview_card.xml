<component>
	<api>
		<prop name="stage_text" type="string" />
		<prop name="mode_title" type="string" />
		<prop name="cycle_summary" type="string" />
		<prop name="cycles_per_day" type="string" />
		<prop name="pump_per_day" type="string" />
		<prop name="window_time" type="string" />
		<prop name="night_break_status" type="string" />
		<prop name="warning_text" type="string" />
	</api>

	<view
		width="452"
		height="198"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_CARD_BG"
		style_bg_opa="255"
		style_radius="20"
		style_pad_all="0"
		style_border_width="1"
		style_border_color="#COLOR_STATUS_INFO"
		style_shadow_width="10"
		style_shadow_opa="18"
		style_shadow_color="#COLOR_SHADOW"
		style_shadow_offset_y="4"
	>
		<!-- Left icon block -->
		<lv_obj
			name="irrigation_overview_icon_bg"
			x="20"
			y="15"
			width="54"
			height="54"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_WATER_TEMP_BG"
			style_bg_opa="90"
			style_radius="14"
			style_border_width="0"
			style_pad_all="0"
		>
			<lv_image
				name="irrigation_overview_drop_icon"
				x="15"
				y="15"
				width="24"
				height="24"
				src="img_irrigation_drop_24px"
				scrollable="false"
				scrollbar_mode="off"
				style_image_recolor="#COLOR_STATUS_INFO"
				style_image_recolor_opa="255"
			/>
		</lv_obj>

		<!-- Stage pill -->
		<lv_obj
			name="irrigation_overview_stage_pill"
			x="94"
			y="11"
			width="122"
			height="22"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_LIGHT_GREEN"
			style_bg_opa="255"
			style_radius="11"
			style_border_width="0"
			style_pad_all="0"
		>
			<lv_label
				name="irrigation_overview_stage_label"
				x="0"
				y="3"
				width="122"
				text="$stage_text"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_PRIMARY_GREEN"
				style_text_font="font_inter_12"
			/>

			<lv_image
				name="irrigation_germination_icon"
				x="5"
				y="3"
				width="18"
				height="18"
				src="img_irrigation_germination_16px"
				scrollable="false"
				scrollbar_mode="off"
				style_image_recolor="#COLOR_PRIMARY_GREEN"
				style_image_recolor_opa="255"
			/>
		</lv_obj>

		<!-- Main title -->
		<lv_image
			name="irrigation_overview_title_drop"
			x="90"
			y="40"
			width="26"
			height="26"
			src="img_irrigation_drop_silhouette_24px"
			scrollable="false"
			scrollbar_mode="off"
			style_image_recolor="#COLOR_STATUS_INFO"
			style_image_recolor_opa="255"
		/>

		<lv_label
			name="irrigation_overview_mode_title_label"
			x="118"
			y="34"
			width="250"
			text="$mode_title"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_26"
		/>

		<lv_label
			name="irrigation_overview_cycle_summary_label"
			x="118"
			y="65"
			width="280"
			text="$cycle_summary"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_SECONDARY"
			style_text_font="font_inter_11"
		/>

		<!-- Metric 1 -->
		<lv_obj
			name="irrigation_overview_cycles_card"
			x="20"
			y="85"
			width="198"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_WATER_TEMP_BG"
			style_bg_opa="50"
			style_radius="11"
			style_border_width="1"
			style_border_color="#COLOR_WATER_TEMP_BG"
			style_pad_all="0"
		>
			<lv_label
				name="irrigation_overview_cycles_value_label"
				x="14"
				y="2"
				width="120"
				text="$cycles_per_day"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_14"
			/>

			<lv_label
				name="irrigation_overview_cycles_caption_label"
				x="14"
				y="20"
				width="130"
				text="CYCLES / DAY"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
			/>
		</lv_obj>

		<!-- Metric 2 -->
		<lv_obj
			name="irrigation_overview_pump_card"
			x="234"
			y="85"
			width="198"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_WATER_TEMP_BG"
			style_bg_opa="50"
			style_radius="11"
			style_border_width="1"
			style_border_color="#COLOR_WATER_TEMP_BG"
			style_pad_all="0"
		>
			<lv_label
				name="irrigation_overview_pump_value_label"
				x="14"
				y="2"
				width="120"
				text="$pump_per_day"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_14"
			/>

			<lv_label
				name="irrigation_overview_pump_caption_label"
				x="14"
				y="20"
				width="130"
				text="PUMP / DAY"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
			/>
		</lv_obj>

		<!-- Metric 3 -->
		<lv_obj
			name="irrigation_overview_window_card"
			x="20"
			y="127"
			width="198"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_WATER_TEMP_BG"
			style_bg_opa="50"
			style_radius="11"
			style_border_width="1"
			style_border_color="#COLOR_WATER_TEMP_BG"
			style_pad_all="0"
		>
			<lv_label
				name="irrigation_overview_window_value_label"
				x="14"
				y="2"
				width="150"
				text="$window_time"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_14"
			/>

			<lv_label
				name="irrigation_overview_window_caption_label"
				x="14"
				y="20"
				width="130"
				text="WINDOW"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
			/>
		</lv_obj>

		<!-- Metric 4 -->
		<lv_obj
			name="irrigation_overview_night_card"
			x="234"
			y="127"
			width="198"
			height="34"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_WATER_TEMP_BG"
			style_bg_opa="50"
			style_radius="11"
			style_border_width="1"
			style_border_color="#COLOR_WATER_TEMP_BG"
			style_pad_all="0"
		>
			<lv_label
				name="irrigation_overview_night_value_label"
				x="14"
				y="2"
				width="120"
				text="$night_break_status"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_PRIMARY"
				style_text_font="font_inter_14"
			/>

			<lv_label
				name="irrigation_overview_night_caption_label"
				x="14"
				y="20"
				width="130"
				text="NIGHT BREAK"
				long_mode="clip"
				style_text_color="#COLOR_TEXT_SECONDARY"
				style_text_font="font_inter_9"
			/>
		</lv_obj>

		<!-- Warning strip -->
		<lv_obj
			name="irrigation_overview_warning_strip"
			x="20"
			y="169"
			width="412"
			height="20"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_WARNING_BG"
			style_bg_opa="255"
			style_radius="7"
			style_border_width="0"
			style_pad_all="0"
		>
			<lv_obj
				name="irrigation_overview_warning_dot"
				x="12"
				y="6"
				width="6"
				height="6"
				scrollable="false"
				scrollbar_mode="off"
				style_bg_color="#COLOR_STATUS_WARNING"
				style_bg_opa="255"
				style_radius="3"
				style_border_width="0"
				style_pad_all="0"
			/>

			<lv_label
				name="irrigation_overview_warning_label"
				x="26"
				y="1"
				width="370"
				text="$warning_text"
				long_mode="clip"
				style_text_color="#COLOR_STATUS_WARNING"
				style_text_font="font_inter_12"
			/>
		</lv_obj>
	</view>
</component>
