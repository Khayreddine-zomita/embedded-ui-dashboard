		<lv_button
			name="nav_home_btn"
			x="0"
			y="0"
			width="96"
			height="40"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="$nav_home_bg_color"
			style_bg_opa="$nav_home_bg_opa"
			style_radius="10"
			style_border_width="0"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_image
				name="nav_home_icon"
				x="40"
				y="5"
				width="16"
				height="16"
				src="img_nav_home"
				scrollable="false"
				scrollbar_mode="off"
				style_image_recolor="$nav_home_text_color"
				style_image_recolor_opa="255"
			/>

			<lv_label
				name="nav_home_label"
				x="0"
				y="24"
				width="96"
				text="HOME"
				long_mode="clip"
				style_text_align="center"
