		height="40"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_DARK_FOREST"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- Slot separators -->
		<lv_obj
			name="nav_divider_1"
			x="95"
			y="0"
			width="1"
			height="40"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_GL_GREEN_DARK"
			style_bg_opa="180"
			style_border_width="0"
			style_pad_all="0"
		/>

		<lv_obj
			name="nav_divider_2"
			x="191"
			y="0"
			width="1"
			height="40"
			scrollable="false"
