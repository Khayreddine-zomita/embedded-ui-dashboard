<component>
	<api>
		<prop name="nav_home_text_color" type="color" />
		<prop name="nav_sensors_text_color" type="color" />
		<prop name="nav_irrigation_text_color" type="color" />
		<prop name="nav_led_text_color" type="color" />
		<prop name="nav_settings_text_color" type="color" />

