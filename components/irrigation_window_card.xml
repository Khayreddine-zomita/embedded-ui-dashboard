<component>
	<api>
		<prop name="start_time" type="string" />
		<prop name="end_time" type="string" />
		<prop name="night_break_label" type="string" />
	</api>

	<styles>
		<!-- Switch OFF state -->
		<style name="style_sw" bg_color="#COLOR_DIVIDER" bg_opa="255" radius="11" border_width="0" />

		<!-- Switch ON state -->
		<style name="style_sw_on" bg_color="#COLOR_STATUS_HEALTHY" bg_opa="255" radius="11" border_width="0" />

		<!-- Switch knob -->
		<style name="style_knob" bg_color="#COLOR_WHITE" bg_opa="255" radius="9" border_width="0" />
	</styles>

	<view
		width="228"
		height="140"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_CARD_BG"
		style_bg_opa="255"
		style_radius="16"
		style_pad_all="0"
		style_border_width="0"
		style_shadow_width="8"
		style_shadow_opa="18"
		style_shadow_color="#COLOR_SHADOW"
		style_shadow_offset_y="3"
	>
		<lv_label
			name="irrigation_window_title"
			x="12"
			y="10"
			width="160"
			text="IRRIGATION WINDOW"
			long_mode="clip"
			style_text_color="#COLOR_PRIMARY_GREEN"
			style_text_font="font_inter_12"
		/>

		<!-- Irrigation Clock Icon -->
		<lv_image
			name="irrigation_clock_icon"
			x="180"
			y="4"
			width="26"
			height="26"
			src="img_irrigation_clock_16px"
			scrollable="false"
			scrollbar_mode="off"
			style_image_recolor="#COLOR_PRIMARY_GREEN"
			style_image_recolor_opa="255"
		/>

		<lv_label
			name="irrigation_start_label"
			x="12"
			y="42"
			width="70"
			text="Start"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_11"
		/>

		<lv_button
			name="irrigation_start_time_btn"
			x="136"
			y="34"
			width="76"
			height="26"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_LIGHT_GREEN"
			style_bg_opa="255"
			style_radius="13"
			style_border_width="0"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="irrigation_start_time_value"
				x="0"
				y="6"
				width="76"
				text="$start_time"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_PRIMARY_GREEN"
				style_text_font="font_inter_12"
			/>
		</lv_button>

		<lv_obj
			x="12"
			y="64"
			width="204"
			height="1"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DIVIDER"
			style_bg_opa="255"
			style_border_width="0"
			style_pad_all="0"
		/>

		<lv_label
			name="irrigation_end_label"
			x="12"
			y="76"
			width="70"
			text="End"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_11"
		/>

		<lv_button
			name="irrigation_end_time_btn"
			x="136"
			y="68"
			width="76"
			height="26"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_LIGHT_GREEN"
			style_bg_opa="255"
			style_radius="13"
			style_border_width="0"
			style_pad_all="0"
			style_shadow_width="0"
		>
			<lv_label
				name="irrigation_end_time_value"
				x="0"
				y="6"
				width="76"
				text="$end_time"
				long_mode="clip"
				style_text_align="center"
				style_text_color="#COLOR_STATUS_HEALTHY"
				style_text_font="font_inter_12"
			/>
		</lv_button>

		<lv_obj
			x="12"
			y="98"
			width="204"
			height="1"
			scrollable="false"
			scrollbar_mode="off"
			style_bg_color="#COLOR_DIVIDER"
			style_bg_opa="255"
			style_border_width="0"
			style_pad_all="0"
		/>

		<lv_label
			name="night_break_text_label"
			x="12"
			y="110"
			width="110"
			text="$night_break_label"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_11"
		/>

		<lv_switch
			name="night_break_switch"
			x="170"
			y="105"
			width="40"
			height="22"
			scrollable="false"
			scrollbar_mode="off"
		>
			<style name="style_sw" />
			<style name="style_sw_on" selector="checked|indicator" />
			<style name="style_knob" selector="knob" />
		</lv_switch>
	</view>
</component>


