<component>
	<api>
		<prop name="bar_title" type="string" />
		<prop name="bar_time" type="string" />
	</api>

	<view
		width="480"
		height="40"
		scrollable="false"
		scrollbar_mode="off"
		style_bg_color="#COLOR_WHITE"
		style_bg_opa="255"
		style_pad_all="0"
		style_border_width="0"
		style_radius="0"
	>
		<!-- Brand title -->
		<lv_label
			name="status_title_1"
			x="10"
			y="13"
			width="170"
			text="GL"
			long_mode="clip"
			style_text_color="#COLOR_STATUS_HEALTHY"
			style_text_font="font_inter_14"
		/>

		<lv_label
			name="status_title_2"
			x="30"
			y="13"
			width="170"
			text="TOWERS"
			long_mode="clip"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_14"
		/>

		<lv_image
			name="status_wifi_icon"
			x="420"
			y="10"
			width="16"
			height="16"
			src="img_top_status_bar_no_wifi"
			scrollable="false"
			scrollbar_mode="off"
			style_image_recolor="#COLOR_TEXT_PRIMARY"
			style_image_recolor_opa="255"
		/>

		<lv_label
			name="status_time"
			x="432"
			y="10"
			width="40"
			text="$bar_time"
			long_mode="clip"
			style_text_align="right"
			style_text_color="#COLOR_TEXT_PRIMARY"
			style_text_font="font_inter_12"
		/>
	</view>
</component>
